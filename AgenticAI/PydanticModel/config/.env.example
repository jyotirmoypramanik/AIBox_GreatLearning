# ============================================================
# OracleDB Agentic Monitor v2.0 — Environment Configuration
# ============================================================

# ── Oracle ──────────────────────────────────────────────────
ORACLE_DSN=localhost:1521/ORCL
ORACLE_USER=monitor_user
ORACLE_PASSWORD=change_me
ORACLE_ALERT_LOG_PATH=C:\app\oracle\diag\rdbms\orcl\orcl\trace\alert_ORCL.log
ORACLE_TRACE_DIR=C:\app\oracle\diag\rdbms\orcl\orcl\trace

# ── Analysis mode ───────────────────────────────────────────
# python | llm | rag | auto (recommended)
ANALYSIS_MODE=auto

# ── LLM ─────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1500

# Local LLM (Ollama / LM Studio) — uncomment to use:
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3:8b

# ── RAG Vector Store ────────────────────────────────────────
VECTOR_STORE_PATH=data/vector_store
VECTOR_STORE_BACKEND=chroma     # chroma | faiss
EMBED_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=4

# ── Email ───────────────────────────────────────────────────
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASSWORD=change_me
ALERT_EMAIL_TO=dba-team@yourcompany.com
ALERT_EMAIL_FROM=dbagent@yourcompany.com
SMTP_USE_TLS=true

# ── Teams ───────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── Agent ───────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=300
ALERT_COOLDOWN_MINUTES=30
MAX_LOG_LINES_PER_POLL=5000
STATE_DB_PATH=data/state/agent_state.db
LOG_LEVEL=INFO
